{
    "absolute": false,
    "blame": false,
    "exitCode": 0,
    "gitignore": true,
    "ignore": [
        "**/*.bin",
        "**/*.config.js",
        "**/*.config.mjs",
        "**/*.config.ts",
        "**/*.css",
        "**/*.d.ts",
        "**/*.eot",
        "**/*.gif",
        "**/*.gz",
        "**/*.html",
        "**/*.ico",
        "**/*.jpeg",
        "**/*.jpg",
        "**/*.json",
        "**/*.md",
        "**/*.png",
        "**/*.sass",
        "**/*.scss",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/*.svg",
        "**/*.tar",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.ttf",
        "**/*.wasm",
        "**/*.woff",
        "**/*.woff2",
        "**/*.xml",
        "**/*.zip",
        "**/.git/**",
        "**/.github/**",
        "**/assets/**",
        "**/.babelrc",
        "**/.babelrc.*",
        "**/babel.config.*",
        "**/benchmarks/**",
        "**/build/**",
        "**/.commitlintrc",
        "**/.commitlintrc.*",
        "**/commitlint.config.*",
        "**/coverage/**",
        "**/dist/**",
        "**/docs/**",
        "**/electron/test/**",
        "**/.eslintignore",
        "**/.eslintrc",
        "**/.eslintrc.*",
        "**/eslint.config.*",
        "**/Gruntfile.*",
        "**/gruntfile.*",
        "**/gulpfile.*",
        "**/html/**",
        "**/.husky/**",
        "**/icons/**",
        "**/lerna.json",
        "**/libs/**",
        "**/.lintstagedrc",
        "**/.lintstagedrc.*",
        "**/lint-staged.config.*",
        "**/node_modules/**",
        "**/package-lock.json",
        "**/pnpm-lock.yaml",
        "**/.prettierignore",
        "**/.prettierrc",
        "**/.prettierrc.*",
        "**/prettier.config.*",
        "**/release/**",
        "**/report/**",
        "**/rollup.config.*",
        "**/scripts/**",
        "**/src/test/**",
        "**/.stylelintignore",
        "**/.stylelintrc",
        "**/.stylelintrc.*",
        "**/stylelint.config.*",
        "**/test/**",
        "**/tests/**",
        "**/tsconfig.json",
        "**/vscode/**",
        "**/webpack.config.*",
        "**/yarn.lock"
    ],
    "ignoreCase": false,
    "maxLines": 10000,
    "maxSize": "1mb",
    "minLines": 10,
    "minTokens": 50,
    "mode": "mild",
    "noSymlinks": true,
    "noTips": true,
    "output": "./reports/jscpd/",
    "pattern": "**/*",
    "reporters": [
        "html",
        "markdown",
        "json",
        "console",
        "badge",
        "xml",
        "csv"
    ],
    "silent": false,
    "skipLocal": false,
    "threshold": 100,
    "verbose": false
}
